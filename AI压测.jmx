          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="从赛事池随机选一场" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def pool = props.get(&quot;BET_POOL&quot;)
if (pool == null || pool.isEmpty()) {
    vars.put(&quot;sel_gidm&quot;, &quot;ib_7764494&quot;)
    vars.put(&quot;sel_gameId&quot;, &quot;7062614&quot;)
    vars.put(&quot;sel_gameType&quot;, &quot;FT&quot;)
    vars.put(&quot;sel_leagueId&quot;, &quot;42&quot;)
    vars.put(&quot;sel_systemId&quot;, &quot;6832360251084001280&quot;)
    vars.put(&quot;sel_homeTeamSuffix&quot;, &quot;&quot;)
    vars.put(&quot;sel_strong&quot;, &quot;H&quot;)
    return
}
def idx = new Random().nextInt(pool.size())
def m = pool[idx]
vars.put(&quot;sel_gidm&quot;, m.gidm)
vars.put(&quot;sel_gameId&quot;, m.gameId)
vars.put(&quot;sel_gameType&quot;, m.gameType)
vars.put(&quot;sel_leagueId&quot;, m.leagueId)
vars.put(&quot;sel_systemId&quot;, m.systemId)
vars.put(&quot;sel_homeTeamSuffix&quot;, m.homeTeamSuffix ?: &quot;&quot;)
vars.put(&quot;sel_strong&quot;, m.strong ?: &quot;H&quot;)</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="解析点水结果（提取最新 ior/ratio）" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

vars.put(&quot;pw_ok&quot;, &quot;0&quot;)
def txt = prev.getResponseDataAsString()
if (!txt) return

def json
try { json = new JsonSlurper().parseText(txt) } catch (e) { return }

if (json?.code != 200) return

// 直接取 data.orderData[0]，无需递归遍历
def found = json?.data?.orderData?.getAt(0)

if (found == null || !found.ior || found.errorCode != null) {
    // 点水失败或赔率不可用，跳过本次投注
    return
}

def ior      = found.ior.toString()
def ratio    = (found.ratio    ?: &quot;&quot;).toString()
def ratioIpo = (found.ratioIpo ?: &quot;&quot;).toString()
def concede  = (found.concede  ?: &quot;&quot;).toString()
def score    = (found.score    ?: &quot;&quot;).toString()
def betItem  = (found.betItem  ?: &quot;&quot;).toString()

vars.put(&quot;pw_ior&quot;,      ior)
vars.put(&quot;pw_ratio&quot;,    ratio)
vars.put(&quot;pw_ratioIpo&quot;, ratioIpo)
vars.put(&quot;pw_concede&quot;,  concede)
vars.put(&quot;pw_score&quot;,    score)
vars.put(&quot;pw_betItem&quot;,  betItem)
vars.put(&quot;pw_ratioType&quot;, (found.ratioType ?: &quot;MH&quot;).toString())
vars.put(&quot;pw_playType&quot;,  (found.playType  ?: &quot;M&quot;).toString())
vars.put(&quot;pw_ok&quot;,       &quot;1&quot;)</stringProp>
            </JSR223PostProcessor>
