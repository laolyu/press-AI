          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="写入 tokens.csv" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.services.FileServer
def loginName = vars.get(&quot;loginName&quot;)
def token = vars.get(&quot;token&quot;)
if (token == null || token.isEmpty() || token == &quot;NA&quot;) {
    log.warn(&quot;login failed: &quot; + loginName + &quot;, resp=&quot; + prev.getResponseDataAsString())
    return
}
def f = new File(FileServer.getFileServer().getBaseDir(), &quot;tokens.csv&quot;)
synchronized(this.getClass()) {
    f.append(loginName + &quot;,&quot; + token + &quot;\n&quot;, &quot;UTF-8&quot;)
}</stringProp>
          </JSR223PostProcessor>
