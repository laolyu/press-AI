        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="清理 tokens.csv">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.services.FileServer
def baseDir = FileServer.getFileServer().getBaseDir()
def f = new File(baseDir, &quot;tokens.csv&quot;)
if (f.exists()) f.delete()
f.createNewFile()
log.info(&quot;tokens.csv cleared at: &quot; + f.absolutePath)
SampleResult.setIgnore()</stringProp>
          </JSR223Sampler>
