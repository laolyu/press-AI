                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&quot;betList&quot;:[{&quot;gidm&quot;:&quot;${sel_gidm}&quot;,&quot;gameId&quot;:&quot;${sel_gameId}&quot;,&quot;gameType&quot;:&quot;${sel_gameType}&quot;,&quot;playType&quot;:&quot;M&quot;,&quot;ratioType&quot;:&quot;MH&quot;,&quot;score&quot;:&quot;&quot;,&quot;ratio&quot;:&quot;&quot;,&quot;betItem&quot;:&quot;&quot;,&quot;ratioKey&quot;:&quot;${sel_gidm}_${sel_gameId}_M_MH&quot;,&quot;systemId&quot;:&quot;${sel_systemId}&quot;,&quot;homeTeamSuffix&quot;:&quot;${sel_homeTeamSuffix}&quot;}],&quot;oddfType&quot;:&quot;H&quot;,&quot;groupId&quot;:1,&quot;sourceType&quot;:true}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
