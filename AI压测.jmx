          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="解析赛事池→props" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

def resp = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(resp)

// 兼容多种返回结构，递归找出含 gidm 的对象
def pool = []
def walk
walk = { node -&gt;
    if (node instanceof Map) {
        if (node.gidm &amp;&amp; node.gameId) {
            pool &lt;&lt; [
                gidm:    node.gidm.toString(),
                gameId:  node.gameId.toString(),
                gameType:(node.gameType ?: &quot;FT&quot;).toString(),
                leagueId:(node.leagueId ?: &quot;&quot;).toString(),
                systemId:(node.systemId ?: &quot;&quot;).toString(),
                homeTeam:(node.homeTeam ?: node.hName ?: &quot;&quot;).toString()
            ]
        }
        node.each { k, v -&gt; walk(v) }
    } else if (node instanceof List) {
        node.each { walk(it) }
    }
}
walk(json)

// 去重
def seen = [:] as LinkedHashMap
pool.each { seen[it.gidm + &quot;_&quot; + it.gameId] = it }
def uniq = seen.values() as List

if (uniq.isEmpty()) {
    log.warn(&quot;赛事池为空，将使用默认 fallback&quot;)
    uniq = [[gidm:&quot;ib_7764494&quot;, gameId:&quot;7062614&quot;, gameType:&quot;FT&quot;, leagueId:&quot;&quot;, systemId:&quot;6832360251084001280&quot;, homeTeam:&quot;巴黎圣日耳曼&quot;]]
}

props.put(&quot;BET_POOL&quot;, uniq)
props.put(&quot;BET_POOL_SIZE&quot;, uniq.size().toString())
log.info(&quot;赛事池大小: &quot; + uniq.size())</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

      </hashTree>

      <!-- ========================== Main: 业务压测 ========================== -->
