          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="解析赛事池→props" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

def resp = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(resp)

// 结构说明：每条赛事顶层有 systemId/homeTeamSuffix/gameType/leagueId/strong，
// 而 gidm/gameId 在嵌套 game 子对象（M.game / HM.game / R.game …）里
// 因此不能递归，直接遍历 data.games 数组并分层取字段
def pool = []
def games = json?.data?.games ?: []
games.each { item -&gt;
    if (!(item instanceof Map)) return
    // 只保留足球 FT 赛事：BK(篮球) 的 gameId 包含 systemId 前缀，与 morePW 接口契约不一致
    if ((item.gameType ?: &quot;FT&quot;) != &quot;FT&quot;) return
    // 只取主赛 M 盘口，确保 morePW/moreBetting 的 playType 一致
    def gameObj = item.M?.game
    if (!gameObj || !gameObj.gidm || !gameObj.gameId) return
    pool &lt;&lt; [
        gidm          : gameObj.gidm.toString(),
        gameId        : gameObj.gameId.toString(),
        gameType      : (item.gameType ?: &quot;FT&quot;).toString(),
        leagueId      : (item.leagueId ?: &quot;&quot;).toString(),
        systemId      : (item.systemId ?: &quot;&quot;).toString(),
        homeTeamSuffix: (item.homeTeamSuffix ?: &quot;&quot;).toString(),
        strong        : (item.strong ?: &quot;H&quot;).toString()
    ]
}

// 按 gidm 去重
def seen = [:] as LinkedHashMap
pool.each { seen[it.gidm] = it }
def uniq = seen.values() as List

if (uniq.isEmpty()) {
    log.warn(&quot;赛事池为空，使用 fallback&quot;)
    uniq = [[gidm:&quot;ib_7764494&quot;, gameId:&quot;7062614&quot;, gameType:&quot;FT&quot;, leagueId:&quot;42&quot;, systemId:&quot;6832360251084001280&quot;, homeTeamSuffix:&quot;&quot;, strong:&quot;H&quot;]]
}

props.put(&quot;BET_POOL&quot;, uniq)
props.put(&quot;BET_POOL_SIZE&quot;, uniq.size().toString())
log.info(&quot;赛事池大小: &quot; + uniq.size())</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
