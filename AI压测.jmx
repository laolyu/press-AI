          <!-- 步骤 1：morePW 点水（拿真实赔率） -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /bet/order/morePW（点水）" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&quot;betList&quot;:[{&quot;gidm&quot;:&quot;${sel_gidm}&quot;,&quot;gameId&quot;:&quot;${sel_gameId}&quot;,&quot;gameType&quot;:&quot;${sel_gameType}&quot;,&quot;playType&quot;:&quot;M&quot;,&quot;ratioType&quot;:&quot;MH&quot;,&quot;score&quot;:&quot;&quot;,&quot;ratio&quot;:&quot;+12470&quot;,&quot;betItem&quot;:&quot;${sel_homeTeam}&quot;,&quot;ratioKey&quot;:&quot;${sel_gidm}_${sel_gameId}_M_MH&quot;,&quot;systemId&quot;:&quot;${sel_systemId}&quot;,&quot;homeTeamSuffix&quot;:&quot;&quot;}],&quot;oddfType&quot;:&quot;H&quot;,&quot;groupId&quot;:1,&quot;sourceType&quot;:true}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.path">/ai/mobile/bet/order/morePW</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="解析点水结果（提取最新 ior/ratio）" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

vars.put(&quot;pw_ok&quot;, &quot;0&quot;)
def txt = prev.getResponseDataAsString()
if (!txt) return

def json
try { json = new JsonSlurper().parseText(txt) } catch (e) { return }

// 找出第一条带 ior 的项
def found = null
def walk
walk = { node -&gt;
    if (found != null) return
    if (node instanceof Map) {
        if (node.ior &amp;&amp; (node.ratio || node.ratioIpo)) { found = node; return }
        node.each { k, v -&gt; walk(v) }
    } else if (node instanceof List) {
        node.each { walk(it) }
    }
}
walk(json)

if (found == null) {
    // 未拿到实时赔率：跳过本次投注（投注采样器用 If Controller 判断）
    return
}

def ior      = (found.ior ?: &quot;2.47&quot;).toString()
def ratio    = (found.ratio ?: &quot;1+2470&quot;).toString()
def ratioIpo = (found.ratioIpo ?: &quot;2470&quot;).toString()
def concede  = (found.concede ?: &quot;1&quot;).toString()
def score    = (found.score ?: &quot;0:0&quot;).toString()
def betItem  = (found.betItem ?: vars.get(&quot;sel_homeTeam&quot;)).toString()

vars.put(&quot;pw_ior&quot;, ior)
vars.put(&quot;pw_ratio&quot;, ratio)
vars.put(&quot;pw_ratioIpo&quot;, ratioIpo)
vars.put(&quot;pw_concede&quot;, concede)
vars.put(&quot;pw_score&quot;, score)
vars.put(&quot;pw_betItem&quot;, betItem)
vars.put(&quot;pw_ok&quot;, &quot;1&quot;)</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>

          <!-- 步骤 2：moreBetting（用真实赔率投注） -->
          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If 点水成功" enabled="true">
            <stringProp name="IfController.condition">${__groovy(vars.get("pw_ok") == "1")}</stringProp>
            <boolProp name="IfController.evaluateAll">false</boolProp>
            <boolProp name="IfController.useExpression">true</boolProp>
          </IfController>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /bet/order/moreBetting（投注）" enabled="true">
